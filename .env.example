# ---- Aegis config ----
# Copy this file to .env and fill in your own values. .env is gitignored.

# Which chain to talk to: "arc" (default, the hackathon target) or "sepolia".
CHAIN="arc"

# RPC endpoint. Optional on Arc - it has a public default baked in, so you can
# leave this blank and it'll use https://rpc.testnet.arc.network. Set it to a
# dedicated RPC (blockdaemon / drpc / quicknode .testnet.arc.network) if the
# public one rate-limits during a live demo.
#   Arc testnet public: https://rpc.testnet.arc.network
#   Sepolia (CHAIN=sepolia): https://ethereum-sepolia-rpc.publicnode.com
RPC_URL=""

# Private key of your THROWAWAY test wallet (0x-prefixed, 64 hex chars).
# Use a dedicated test wallet, never a personal one, even on testnet.
# On Arc there is no separate gas token - fund this wallet with testnet USDC
# from https://faucet.circle.com and that same USDC pays for gas AND payments.
PRIVATE_KEY=""

# USDC token contract. Optional on Arc - defaults to the ERC-20 interface at
# 0x3600000000000000000000000000000000000000 (6 decimals). On Sepolia set it to
# Circle's test USDC: 0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
USDC_ADDRESS=""

# Recipient A: a good, normal EOA (any second address you control or know).
GOOD_RECIPIENT=""

# Recipient B: the malicious contract (filled after deploy-bad-contract.js runs).
BAD_RECIPIENT=""

# AegisGuard contract address (filled after deploy-guard.js runs).
# This is the on-chain firewall the agent routes payments through.
AEGIS_GUARD=""

# The agent's x402 signing wallet (address of a SECOND throwaway wallet, distinct
# from PRIVATE_KEY above). It signs EIP-3009 payment authorizations and holds only
# a small float - the treasury refills it through the guard (ensureFloat), so the
# daily limit caps x402 spend too. Leave blank if you're not running the x402 demo.
X402_WALLET=""
