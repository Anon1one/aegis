# ---- Aegis config ----
# Copy this file to .env and fill in your own values. .env is gitignored.

# Sepolia RPC endpoint. Free options: Alchemy, Infura, or public:
#   https://rpc.sepolia.org  (public, flaky)
#   https://ethereum-sepolia-rpc.publicnode.com  (public, decent)
RPC_URL="https://ethereum-sepolia-rpc.publicnode.com"

# Private key of your THROWAWAY test wallet (0x-prefixed, 64 hex chars).
# Use a dedicated test wallet, never a personal one, even on testnet.
PRIVATE_KEY=""

# USDC token contract on Sepolia (Circle official test USDC).
# Confirm this against your wallet balance before trusting it.
USDC_ADDRESS="0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238"

# Recipient A: a good, normal EOA (any second address you control or know).
GOOD_RECIPIENT=""

# Recipient B: the malicious contract (filled after deploy-bad-contract.js runs).
BAD_RECIPIENT=""

# AegisGuard contract address (filled after deploy-guard.js runs).
# This is the on-chain firewall the agent routes payments through.
AEGIS_GUARD=""
